#!/bin/bash
set -e  # Exit immediately if any command fails

# --- UI Color Configuration ---
BOLD='\033[1m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

start_time=$(date +%s)

printf "${BOLD}${BLUE}󱐋 Husky:${NC} Analyzing staged files...\n"

# Filter staged files by extensions
# Supports: js, ts, tsx, css, cjs, mjs, graphql, json
EXTS="\.(js|ts|tsx|css|cjs|mjs|graphql|gql|json)$"
git_diff=$(git diff --cached --name-only --diff-filter=ACM | grep -E "$EXTS" || true)

# Skip Husky if no relevant files are found
if [ -z "$git_diff" ]; then
  echo -e "${YELLOW}⏩ No relevant files staged. Skipping pre-commit checks.${NC}"
  exit 0
fi

echo -e "${CYAN}🏗️  Validating changes before commit...${NC}\n"

# Helper function to execute steps with status tracking
run_step() {
  local step_num=$1
  local step_name=$2
  local command=$3

  echo -e "${BOLD}[$step_num/4]${NC} ${step_name}..."
  if eval "$command"; then
    echo -e "   ${GREEN}✓ Success${NC}"
  else
    echo -e "   ${RED}✗ Failed${NC}"
    echo -e "\n${RED}${BOLD}ABORTING COMMIT:${NC} Please fix the errors above."
    exit 1
  fi
}

# --- Execution Pipeline ---

# Step 1: Prettify staged files
run_step "1" "Formatting code styles" "pnpm prettier:staged"

# Step 2: Run ESLint on staged files
run_step "2" "Linting project" "pnpm lint-staged"

# Step 3: Check TypeScript types
run_step "3" "Type checking" "pnpm check-types"

# Step 4: Re-stage modified files after formatting
echo -e "${BOLD}[4/4]${NC} Updating staged changes..."
echo "$git_diff" | xargs git add
echo -e "   ${GREEN}✓ Files updated${NC}"

# --- Summary ---
end_time=$(date +%s)
runtime=$((end_time - start_time))

echo -e "\n${BOLD}--------------------------------${NC}"
echo -e "${GREEN}✔${NC} ${BOLD}Pre-commit checks passed!${NC}"
echo -e "⏱️  Execution time: ${CYAN}${runtime}s${NC}"
echo -e "${BOLD}--------------------------------${NC}\n"