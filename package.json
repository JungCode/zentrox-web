{
  "name": "zentrox-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3100",
    "build": "next build -p 3100",
    "start": "next start -p 3100",
    "codegen": "node scripts/codegen.js",
    "lint": "next lint",
    "prepare": "husky",
    "check-types": "NODE_OPTIONS=--max-old-space-size=16384 tsgo --noEmit --pretty",
    "prettier:staged": "git diff --cached --name-only --diff-filter=ACM | grep -E '\\.(js|ts|jsx|tsx)$' | xargs -r prettier --write",
    "lint-staged": "git diff --cached --name-only --diff-filter=ACM | grep -E '\\.(js|ts|jsx|tsx)$' | xargs -r eslint --fix"
  },
  "dependencies": {
    "@apollo/client": "^4.1.9",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@typescript/native-preview": "7.0.0-dev.20260401.1",
    "graphql": "^16.13.2",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@graphql-codegen/cli": "^6.3.1",
    "@graphql-codegen/near-operation-file-preset": "^5.1.0",
    "@graphql-codegen/typescript-react-apollo": "^4.4.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.0.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
